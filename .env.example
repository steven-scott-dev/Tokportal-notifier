# TokPortal Notifier — Environment Variables
# Copy this to .env and fill in your values

# Required: Your cmId from TokPortal
TOKPORTAL_CM_ID=your_cm_id_here

# Required: Discord webhook URL
# Create one at: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Optional: Full Cookie header if TokPortal requires session auth
# Grab from browser DevTools → Network tab → any API request → Request Headers → Cookie
TOKPORTAL_COOKIE=

# Optional: Poll interval in milliseconds (default: 15000 = 15 seconds)
POLL_INTERVAL_MS=15000
